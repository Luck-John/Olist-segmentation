   "metadata": {},
   "source": [
    "<div style='background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);padding:50px;border-radius:12px;text-align:center;color:#f5f5f5;font-family:Segoe UI'>\n",
    "<h1 style='font-size:2.5em;font-weight:800;text-transform:uppercase;letter-spacing:3px'>Modélisation de Segmentation Clients Olist</h1>\n",
    "<hr style='width:120px;border:2px solid #f1c40f;margin:25px auto'>\n",
    "<p style='font-size:1.4em;font-style:italic'>Machine Learning 2 - Windsurf</p>\n",
    "</div>"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Ce notebook s'inscrit dans le cadre d'une mission de data science pour Olist, une entreprise brésilienne spécialisée dans la vente sur les marketplaces en ligne.\n",
    "\n",
    "L'objectif principal est de segmenter les clients afin d'aider les équipes marketing à mieux comprendre les différents profils d'utilisateurs et à adapter leurs stratégies de communication.\n",
    "\n",
    "Dans ce notebook, nous allons implémenter différents algorithmes de clustering pour identifier les segments de clients optimaux."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Importation des bibliothèques nécessaires\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Scikit-learn pour le clustering et la réduction dimensionnelle\n",
    "from sklearn.preprocessing import StandardScaler, MinMaxScaler\n",
    "from sklearn.decomposition import PCA, KernelPCA\n",
    "from sklearn.cluster import KMeans, AgglomerativeClustering, DBSCAN\n",
    "from sklearn.metrics import silhouette_score, davies_bouldin_score, calinski_harabasz_score\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "# Bibliothèques pour la visualisation\n",
    "import plotly.graph_objects as go\n",
    "import plotly.express as px\n",
    "from scipy.cluster.hierarchy import dendrogram, linkage\n",
    "\n",
    "# Gestion des modèles\n",
    "import pickle\n",
    "import os\n",
    "import time\n",
    "\n",
    "# Configuration\n",
    "pd.set_option('display.max_columns', 999)\n",
    "pd.set_option('display.float_format', '{:.2f}'.format)\n",
    "sns.set(style='whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "RANDOM_STATE = 42"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Chargement et Préparation des Données"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Chargement de la base finale\n",
    "try:\n",
    "    df_client = pd.read_csv('../data/base_final.csv')\n",
    "    print(f\"Base chargée avec succès : {df_client.shape}\")\n",
    "except FileNotFoundError:\n",
    "    # Alternative si le fichier n'est pas trouvé\n",
    "    df_client = pd.read_csv('../data/Base.csv')\n",
    "    print(f\"Base alternative chargée : {df_client.shape}\")\n",
    "\n",
    "# Affichage des informations sur les données\n",
    "print(f\"\\nColonnes disponibles : {df_client.columns.tolist()}\")\n",
    "print(f\"\\nTypes de données :\\n{df_client.dtypes}\")\n",
    "print(f\"\\nValeurs manquantes :\\n{df_client.isna().sum()}\")\n",
    "df_client.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Feature Engineering et Prétraitement"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sélection des variables pertinentes pour le clustering\n",
    "# Variables numériques\n",
    "numeric_features = [\n",
    "    'price', 'freight_value', 'payment_value', 'Nb_tot_pdts', \n",
    "    'Tot_moy_achats', 'Mont_max_achats', 'nb_payment_dif_com', \n",
    "    'nmbre_echea_tot', 'nb_commandes', 'Note_Moy_Com', \n",
    "    'Nb_moy_pdts_par_com'\n",
    "]\n",
    "\n",
    "# Variables catégorielles\n",
    "categorical_features = [\n",
    "    'customer_city', 'customer_state', 'payment_type', \n",
    "    'product_category_name_english', 'Cat_la_plus_achetee'\n",
    "]\n",
    "\n",
    "# Filtrer les colonnes qui existent dans le dataset\n",
    "available_numeric = [col for col in numeric_features if col in df_client.columns]\n",
    "available_categorical = [col for col in categorical_features if col in df_client.columns]\n",
    "\n",
    "print(f\"Variables numériques disponibles : {available_numeric}\")\n",
    "print(f\"Variables catégorielles disponibles : {available_categorical}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Préparation des données\n",
    "df_model = df_client.copy()\n",
    "\n",
    "# Suppression des colonnes inutiles\n",
    "cols_to_drop = ['customer_unique_id', 'customer_id', 'Unnamed: 0']\n",
    "for col in cols_to_drop:\n",
    "    if col in df_model.columns:\n",
    "        df_model.drop(col, axis=1, inplace=True)\n",
    "\n",
    "# Gestion des variables catégorielles\n",
    "if 'payment_type' in df_model.columns:\n",
    "    # Encodage one-hot pour le type de paiement\n",
    "    payment_dummies = pd.get_dummies(df_model['payment_type'], prefix='payment')\n",
    "    df_model = pd.concat([df_model, payment_dummies], axis=1)\n",
    "    df_model.drop('payment_type', axis=1, inplace=True)\n",
    "\n",
    "# Sélection des variables numériques pour le clustering\n",
    "X = df_model.select_dtypes(include=['int64', 'float64', 'uint8'])\n",
    "\n",
    "print(f\"Dataset final pour modélisation : {X.shape}\")\n",
    "print(f\"Colonnes utilisées : {X.columns.tolist()}\")\n",
    "X.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Division des Données et Standardisation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Division en ensembles d'entraînement et de test\n",
    "X_train, X_test = train_test_split(\n",
    "    X, test_size=0.2, random_state=RANDOM_STATE, stratify=None\n",
    ")\n",
    "\n",
    "print(f\"Taille ensemble d'entraînement : {X_train.shape}\")\n",
    "print(f\"Taille ensemble de test : {X_test.shape}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Standardisation des données\n",
    "scaler = StandardScaler()\n",
    "X_train_scaled = scaler.fit_transform(X_train)\n",
    "X_test_scaled = scaler.transform(X_test)\n",
    "\n",
    "# Conversion en DataFrame pour conserver les noms de colonnes\n",
    "X_train_scaled = pd.DataFrame(X_train_scaled, columns=X_train.columns)\n",
    "X_test_scaled = pd.DataFrame(X_test_scaled, columns=X_test.columns)\n",
    "\n",
    "print(\"Données standardisées avec succès\")\n",
    "X_train_scaled.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Réduction Dimensionnelle avec ACP"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Détermination du nombre optimal de composantes\n",
    "pca = PCA()\n",
    "pca.fit(X_train_scaled)\n",
    "\n",
    "# Calcul de la variance expliquée\n",
    "variance_explained = pca.explained_variance_ratio_ * 100\n",
    "cumulative_variance = variance_explained.cumsum()\n",
    "\n",
    "# Visualisation de la variance expliquée\n",
    "plt.figure(figsize=(12, 6))\n",
    "plt.bar(range(1, len(variance_explained) + 1), variance_explained, alpha=0.7, label='Variance individuelle')\n",
    "plt.plot(range(1, len(cumulative_variance) + 1), cumulative_variance, 'ro-', label='Variance cumulée')\n",
    "plt.axhline(y=95, color='g', linestyle='--', label='95% de variance')\n",
    "plt.xlabel('Nombre de composantes')\n",
    "plt.ylabel('Variance expliquée (%)')\n",
    "plt.title('Analyse de la variance expliquée par l\\'ACP')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "# Nombre de composantes pour 95% de variance\n",
    "n_components_95 = np.where(cumulative_variance >= 95)[0][0] + 1\n",
    "print(f\"Nombre de composantes pour 95% de variance : {n_components_95}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Application de l'ACP avec le nombre optimal de composantes\n",
    "pca_final = PCA(n_components=n_components_95, random_state=RANDOM_STATE)\n",
    "X_train_pca = pca_final.fit_transform(X_train_scaled)\n",
    "X_test_pca = pca_final.transform(X_test_scaled)\n",
    "\n",
    "print(f\"Données réduites de {X_train_scaled.shape[1]} à {X_train_pca.shape[1]} dimensions\")\n",
    "print(f\"Variance expliquée totale : {cumulative_variance[n_components_95-1]:.2f}%\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. K-Means Clustering"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.1. Détermination du nombre optimal de clusters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Méthode du coude pour déterminer le nombre optimal de clusters\n",
    "inertias = []\n",
    "silhouette_scores = []\n",
    "k_range = range(2, 15)\n",
    "\n",
    "for k in k_range:\n",
    "    kmeans = KMeans(n_clusters=k, random_state=RANDOM_STATE, n_init=10)\n",
    "    kmeans.fit(X_train_pca)\n",
    "    inertias.append(kmeans.inertia_)\n",
    "    silhouette_scores.append(silhouette_score(X_train_pca, kmeans.labels_))\n",
    "\n",
    "# Visualisation\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 5))\n",
    "\n",
    "# Méthode du coude\n",
    "ax1.plot(k_range, inertias, 'bo-')\n",
    "ax1.set_xlabel('Nombre de clusters (k)')\n",
    "ax1.set_ylabel('Inertie')\n",
    "ax1.set_title('Méthode du coude')\n",
    "ax1.grid(True)\n",
    "\n",
    "# Coefficient de silhouette\n",
    "ax2.plot(k_range, silhouette_scores, 'ro-')\n",
    "ax2.set_xlabel('Nombre de clusters (k)')\n",
    "ax2.set_ylabel('Coefficient de silhouette')\n",
    "ax2.set_title('Coefficient de silhouette')\n",
    "ax2.grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Identification du nombre optimal de clusters\n",
    "optimal_k_silhouette = k_range[np.argmax(silhouette_scores)]\n",
    "print(f\"Nombre optimal de clusters (silhouette) : {optimal_k_silhouette}\")\n",
    "print(f\"Coefficient de silhouette maximal : {max(silhouette_scores):.3f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.2. Application du K-Means optimal"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Application du K-Means avec le nombre optimal de clusters\n",
    "kmeans_final = KMeans(n_clusters=optimal_k_silhouette, random_state=RANDOM_STATE, n_init=10)\n",
    "kmeans_final.fit(X_train_pca)\n",
    "\n",
    "# Prédiction sur les ensembles d'entraînement et de test\n",
    "train_clusters = kmeans_final.predict(X_train_pca)\n",
    "test_clusters = kmeans_final.predict(X_test_pca)\n",
    "\n",
    "# Évaluation du modèle\n",
    "train_silhouette = silhouette_score(X_train_pca, train_clusters)\n",
    "test_silhouette = silhouette_score(X_test_pca, test_clusters)\n",
    "train_db = davies_bouldin_score(X_train_pca, train_clusters)\n",
    "test_db = davies_bouldin_score(X_test_pca, test_clusters)\n",
    "\n",
    "print(f\"K-Means avec {optimal_k_silhouette} clusters :\")\n",
    "print(f\"  - Silhouette (train) : {train_silhouette:.3f}\")\n",
    "print(f\"  - Silhouette (test) : {test_silhouette:.3f}\")\n",
    "print(f\"  - Davies-Bouldin (train) : {train_db:.3f}\")\n",
    "print(f\"  - Davies-Bouldin (test) : {test_db:.3f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.3. Visualisation des clusters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualisation des clusters sur les deux premières composantes principales\n",
    "plt.figure(figsize=(12, 8))\n",
    "scatter = plt.scatter(X_train_pca[:, 0], X_train_pca[:, 1], c=train_clusters, \n",
    "                      cmap='viridis', alpha=0.6, s=50)\n",
    "plt.scatter(kmeans_final.cluster_centers_[:, 0], kmeans_final.cluster_centers_[:, 1], \n",
    "           c='red', marker='x', s=200, linewidths=3, label='Centroïdes')\n",
    "plt.xlabel(f'PC1 ({pca_final.explained_variance_ratio_[0]*100:.1f}% variance)')\n",
    "plt.ylabel(f'PC2 ({pca_final.explained_variance_ratio_[1]*100:.1f}% variance)')\n",
    "plt.title(f'Clusters K-Means (k={optimal_k_silhouette})')\n",
    "plt.colorbar(scatter, label='Cluster')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Classification Ascendante Hiérarchique (CAH)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Application de la CAH\n",
    "cah = AgglomerativeClustering(n_clusters=optimal_k_silhouette, linkage='ward')\n",
    "cah_labels = cah.fit_predict(X_train_pca)\n",
    "\n",
    "# Évaluation\n",
    "cah_silhouette = silhouette_score(X_train_pca, cah_labels)\n",
    "cah_db = davies_bouldin_score(X_train_pca, cah_labels)\n",
    "\n",
    "print(f\"CAH avec {optimal_k_silhouette} clusters :\")\n",
    "print(f\"  - Silhouette : {cah_silhouette:.3f}\")\n",
    "print(f\"  - Davies-Bouldin : {cah_db:.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualisation du dendrogramme (échantillon pour la performance)\n",
    "sample_size = min(1000, len(X_train_pca))\n",
    "sample_indices = np.random.choice(len(X_train_pca), sample_size, replace=False)\n",
    "X_sample = X_train_pca[sample_indices]\n",
    "\n",
    "plt.figure(figsize=(15, 10))\n",
    "linkage_matrix = linkage(X_sample, method='ward')\n",
    "dendrogram(linkage_matrix, truncate_mode='lastp', p=20, show_leaf_counts=True)\n",
    "plt.title('Dendrogramme (CAH - Ward)')\n",
    "plt.xlabel('Index des échantillons')\n",
    "plt.ylabel('Distance')\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. DBSCAN Clustering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Détermination des paramètres optimaux pour DBSCAN\n",
    "# Méthode du coude pour trouver epsilon\n",
    "from sklearn.neighbors import NearestNeighbors\n",
    "\n",
    "nn = NearestNeighbors(n_neighbors=5)\n",
    "nn.fit(X_train_pca)\n",
    "distances, indices = nn.kneighbors(X_train_pca)\n",
    "distances = np.sort(distances[:, 4], axis=0)\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.plot(distances)\n",
    "plt.title('Méthode du coude pour DBSCAN (epsilon)')\n",
    "plt.xlabel('Points triés par distance')\n",
    "plt.ylabel('Distance au 5ème plus proche voisin')\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Application de DBSCAN\n",
    "# Choix d'epsilon basé sur le graphique précédent\n",
    "epsilon = distances[int(len(distances) * 0.9)]  # 90ème percentile\n",
    "min_samples = 5\n",
    "\n",
    "dbscan = DBSCAN(eps=epsilon, min_samples=min_samples)\n",
    "dbscan_labels = dbscan.fit_predict(X_train_pca)\n",
    "\n",
    "# Nombre de clusters (en excluant le bruit)\n",
    "n_clusters_dbscan = len(set(dbscan_labels)) - (1 if -1 in dbscan_labels else 0)\n",
    "n_noise = list(dbscan_labels).count(-1)\n",
    "\n",
    "print(f\"DBSCAN résultats :\")\n",
    "print(f\"  - Nombre de clusters : {n_clusters_dbscan}\")\n",
    "print(f\"  - Points de bruit : {n_noise} ({n_noise/len(dbscan_labels)*100:.1f}%)\")\n",
    "print(f\"  - Epsilon utilisé : {epsilon:.3f}\")\n",
    "\n",
    "# Évaluation seulement si nous avons des clusters\n",
    "if n_clusters_dbscan > 1:\n",
    "    # Exclure les points de bruit pour l'évaluation\n",
    "    mask = dbscan_labels != -1\n",
    "    if np.sum(mask) > 1:\n",
    "        dbscan_silhouette = silhouette_score(X_train_pca[mask], dbscan_labels[mask])\n",
    "        dbscan_db = davies_bouldin_score(X_train_pca[mask], dbscan_labels[mask])\n",
    "        print(f\"  - Silhouette : {dbscan_silhouette:.3f}\")\n",
    "        print(f\"  - Davies-Bouldin : {dbscan_db:.3f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Comparaison des Algorithmes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Synthèse des performances\n",
    "results = {\n",
    "    'Algorithme': ['K-Means', 'CAH', 'DBSCAN'],\n",
    "    'Nombre de clusters': [optimal_k_silhouette, optimal_k_silhouette, n_clusters_dbscan],\n",
    "    'Silhouette': [train_silhouette, cah_silhouette, \n",
    "                   dbscan_silhouette if n_clusters_dbscan > 1 else np.nan],\n",
    "    'Davies-Bouldin': [train_db, cah_db, \n",
    "                      dbscan_db if n_clusters_dbscan > 1 else np.nan]\n",
    "}\n",
    "\n",
    "results_df = pd.DataFrame(results)\n",
    "print(\"\\nComparaison des algorithmes de clustering :\")\n",
    "print(results_df.to_string(index=False))\n",
    "\n",
    "# Visualisation comparative\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 5))\n",
    "\n",
    "# Silhouette\n",
    "ax1.bar(results_df['Algorithme'], results_df['Silhouette'], color=['blue', 'green', 'orange'])\n",
    "ax1.set_ylabel('Coefficient de silhouette')\n",
    "ax1.set_title('Comparaison - Silhouette (plus haut = meilleur)')\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Davies-Bouldin\n",
    "ax2.bar(results_df['Algorithme'], results_df['Davies-Bouldin'], color=['blue', 'green', 'orange'])\n",
    "ax2.set_ylabel('Index de Davies-Bouldin')\n",
    "ax2.set_title('Comparaison - Davies-Bouldin (plus bas = meilleur)')\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Analyse des Clusters (avec le meilleur algorithme)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sélection du meilleur algorithme basé sur le coefficient de silhouette\n",
    "best_algorithm = results_df.loc[results_df['Silhouette'].idxmax(), 'Algorithme']\n",
    "print(f\"Meilleur algorithme : {best_algorithm}\")\n",
    "\n",
    "# Utilisation des labels du meilleur algorithme\n",
    "if best_algorithm == 'K-Means':\n",
    "    best_labels = train_clusters\n",
    "elif best_algorithm == 'CAH':\n",
    "    best_labels = cah_labels\n",
    "else:\n",
    "    best_labels = dbscan_labels\n",
    "\n",
    "# Ajout des labels au dataframe original\n",
    "X_train_with_clusters = X_train.copy()\n",
    "X_train_with_clusters['cluster'] = best_labels\n",
